[Unit]
Description=Asterisk CC AMI state listener
After=network-online.target asterisk.service
Wants=asterisk.service

[Service]
Type=simple
EnvironmentFile=/etc/cc/cc.env
ExecStart=/opt/cc/scripts/ami_state_listener.py
Restart=on-failure
RestartSec=5s
User=asterisk
Group=asterisk

[Install]
WantedBy=multi-user.target
