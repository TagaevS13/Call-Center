      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres-cc"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 12},
      "id": 9,
      "targets": [{
        "datasource": {"type": "postgres", "uid": "postgres-cc"},
        "format": "table",
        "rawSql": "SELECT id, name AS queue, description, sla_seconds FROM queues ORDER BY id LIMIT 50",
        "refId": "A"
      }],
      "title": "Skill queues (Postgres)",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres-cc"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 12},
      "id": 10,
      "targets": [{
        "datasource": {"type": "postgres", "uid": "postgres-cc"},
        "format": "table",
        "rawSql": "SELECT queuename, sum(offered) AS offered, sum(handled) AS handled, sum(abandoned) AS abandoned, round(avg(asa)::numeric,1) AS asa, round(avg(sla_share)::numeric,3) AS sla FROM mv_queue_calls_5m WHERE bucket > now() - interval '24 hours' GROUP BY queuename ORDER BY offered DESC",
        "refId": "A"
      }],
      "title": "SLA last 24h (mv_queue_calls_5m)",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres-cc"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "id": 11,
      "targets": [{
        "datasource": {"type": "postgres", "uid": "postgres-cc"},
        "format": "table",
        "rawSql": "SELECT queuename, waiting FROM v_queue_realtime ORDER BY waiting DESC",
        "refId": "A"
      }],
      "title": "Realtime queue depth",
      "type": "table"
    }
