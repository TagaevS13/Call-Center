      "id": 2,
      "options": {"colorMode": "value", "graphMode": "none"},
      "targets": [{
        "datasource": {"type": "postgres", "uid": "postgres-cc"},
        "format": "table",
        "rawSql": "SELECT count(*) AS agents FROM agents",
        "refId": "A"
      }],
      "title": "Agents in DB",
      "type": "stat"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres-cc"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none"},
      "targets": [{
        "datasource": {"type": "postgres", "uid": "postgres-cc"},
        "format": "table",
        "rawSql": "SELECT COALESCE(sum(waiting), 0) AS waiting FROM v_queue_realtime",
        "refId": "A"
      }],
      "title": "Calls waiting",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1, "min": 0}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "id": 4,
      "targets": [{"expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))", "refId": "A"}],
      "title": "CPU busy (avg)",
      "type": "gauge"
