# Use 127.0.0.1 for lab (Asterisk runs with network_mode: host and cannot resolve "postgres").
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DB=asterisk_cc
PG_USER=asterisk
PG_PASSWORD=changeme
PG_SUPER_USER=postgres
PG_SUPER_PASSWORD=changeme

ASTERISK_AMI_USER=cti
ASTERISK_AMI_PASSWORD=changeme
ASTERISK_ARI_USER=ari
ASTERISK_ARI_PASSWORD=changeme

GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://172.16.6.183:3001/

# Docker image (andrius/asterisk tags: 20-cert, 20, 22, latest)
ASTERISK_IMAGE=andrius/asterisk:20-cert

# Publish ports (avoid SMSC conflicts on same host)
PG_PUBLISH_PORT=5433
WEBUI_PUBLISH_PORT=9000
GRAFANA_PUBLISH_PORT=3001
PROMETHEUS_PUBLISH_PORT=9091

PUBLIC_DOMAIN=172.16.6.183
# WebRTC-профиль агента: manual (ручной dtls/ice/rtcp_mux, bundle=no, webrtc=no — текущее)
# или standard (webrtc=yes). A/B при one-way к браузеру — см. ops/audio-two-way-runbook.md.
AGENT_WEBRTC_MODE=manual
# GSM SIP/RTP на enp13s4f0 (совпадает с SDP в 200 OK для UMG)
GSM_MEDIA_ADDRESS=172.16.4.19
GSM_SIGNAL_ADDRESS=172.16.4.19
INTERNAL_CIDR=10.0.0.0/8
# Доверенный GSM/SBC — вход без логина, только по IP
SIP_PROVIDER_SIGNAL=10.1.5.10
SIP_PROVIDER_MEDIA=10.1.5.75
# Подсети GSM (identify PJSIP + ip route), см. ops/gsm-network-routes.md
SIP_PROVIDER_SIGNAL_NET=10.1.5.8/29
SIP_PROVIDER_MEDIA_NET=10.1.5.64/27
GSM_ROUTE_NET=10.1.5.0/24
GSM_ROUTE_SIGNAL_NET=10.1.5.8/29
GSM_ROUTE_MEDIA_NET=10.1.5.64/27
GSM_ROUTE_VIA=172.16.4.1
GSM_ROUTE_DEV=enp13s4f0

RECORDINGS_DIR=/var/spool/asterisk/recordings
ARCHIVE_S3_BUCKET=
ARCHIVE_S3_ENDPOINT=
ARCHIVE_S3_KEY=
ARCHIVE_S3_SECRET=
